name = "opc-super-individual-api"
main = "cloudflare-worker.js"
compatibility_date = "2026-06-24"

# 创建 KV 后，把 id 填到这里
[[kv_namespaces]]
binding = "MATERIALS_KV"
id = "YOUR_KV_NAMESPACE_ID"

# 创建 R2 bucket 后使用；如果暂时不配置，云端也能存素材卡片信息，但不能存真实文件。
[[r2_buckets]]
binding = "MATERIALS_BUCKET"
bucket_name = "opc-materials"

# 不要把真实卡密写进仓库。部署时用：
# wrangler secret put VIEW_CODE
# wrangler secret put EDIT_CODE
